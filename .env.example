# Port mapping untuk Docker (copy ke .env di root project)
# Local dev tetap pakai port default di backend/.env dan frontend/.env.local

DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=taskdb

# Docker host ports (beda dari local agar bisa jalan bersamaan)
DB_PORT=5433
MONGO_PORT=27018
BACKEND_PORT=3100
FRONTEND_PORT=8080

MONGO_DB_NAME=task_logs
VITE_API_URL=http://localhost:3100
